# App
APP_NAME="Conversational Agent"
ENVIRONMENT=local
LOG_LEVEL=INFO

# OpenAI. Leave OPENAI_API_KEY empty for deterministic local demo responses.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local host URLs. docker-compose overrides DATABASE_URL for the app container.
DATABASE_URL=postgresql+psycopg://life_os:life_os@localhost:5432/life_os
REDIS_URL=redis://localhost:6379/0
SHORT_TERM_TTL_SECONDS=3600
SHORT_TERM_MAX_MESSAGES=20
CONSOLIDATION_TURN_THRESHOLD=10

# Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
